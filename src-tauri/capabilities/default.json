{
    "$schema": "../gen/schemas/capabilities.json",
    "identifier": "default",
    "description": "Default capabilities for the Discord Quest Helper app",
    "windows": [
        "main"
    ],
    "permissions": [
        "core:default",
        "core:event:default",
        "core:event:allow-listen",
        "core:event:allow-emit",
        "core:window:default",
        "core:window:allow-start-dragging",
        "core:window:allow-close",
        "core:window:allow-minimize",
        "core:window:allow-toggle-maximize",
        "shell:allow-open",
        "fs:allow-exists",
        "fs:allow-mkdir",
        "fs:allow-write-text-file",
        "fs:scope-document-recursive",
        "fs:scope-desktop-recursive",
        "fs:scope-download-recursive",
        "dialog:allow-save",
        "dialog:allow-open"
    ]
}